rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read and write their own data
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow users to read and write their own chat data
    match /users/{userId}/chats/{chatId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow users to read and write their own flashcard data
    match /users/{userId}/flashcards/{document} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow users to read and write their own quiz data
    match /users/{userId}/quizzes/{document} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow users to read and write their own segment data
    match /users/{userId}/segments/{document} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow users to read and write their own stats (streak, cards reviewed, etc.)
    match /userStats/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
